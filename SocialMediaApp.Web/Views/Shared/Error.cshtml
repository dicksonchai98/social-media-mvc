@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4 p-md-5">
        @if (Model.StatusCode.HasValue)
        {
            <p class="text-secondary mb-2">HTTP @Model.StatusCode</p>
        }
        <h1 class="text-danger h3 mb-3">@Model.Title</h1>
        <p class="mb-4">@Model.Message</p>

        @if (Model.ShowRequestId)
        {
            <p class="mb-3">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <div class="d-flex gap-2">
            <a class="btn btn-primary" asp-controller="Posts" asp-action="Index">回到首頁</a>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Login">前往登入</a>
            }
        </div>
    </div>
</div>
